# OpenAI
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_QUALITY=high
OPENAI_IMAGE_TIMEOUT_MS=900000
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_VISION_MODEL=gpt-4o-mini
OPENAI_TEXT_MODEL=gpt-4o-mini

# Supabase (Design Brain database)
# Dashboard → Project Settings → API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_PUBLISHABLE_KEY=

# Supabase Auth — backend JWT verification
AUTH_JWKS_URL=https://YOUR_PROJECT_REF.supabase.co/auth/v1/.well-known/jwks.json
AUTH_ISSUER=https://YOUR_PROJECT_REF.supabase.co/auth/v1
AUTH_AUDIENCE=authenticated

# Supabase Auth — frontend build-time public values (never use service_role here)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=

# Supabase Storage — catalog logo uploads (Settings → API → service_role key)
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_CATALOG_BUCKET=catalog-logos

# Dashboard → Project Settings → Database → Database password
SUPABASE_PROJECT_REF=YOUR_PROJECT_REF
SUPABASE_DB_PASSWORD=

# Recommended for long-running dev server (Supabase → Connect → Session pooler, port 5432)
# Host must be aws-0-REGION.pooler.supabase.com — not REGION.pooler.supabase.com
# Example (Sydney): aws-0-ap-southeast-2.pooler.supabase.com
# DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-ap-southeast-2.pooler.supabase.com:5432/postgres

# Direct connection for SQL migrations and maintenance
# DIRECT_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-ap-southeast-2.pooler.supabase.com:5432/postgres
# DATABASE_CONNECTION_LIMIT=5
# DATABASE_STATEMENT_TIMEOUT_MS=30000

# Optional: direct connection if your network supports IPv6 or the project has the IPv4 add-on
# DATABASE_URL=postgresql://postgres:PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require

# Design Brain — web research (parallel search; Wikipedia + Archive always available)
TAVILY_API_KEY=
BRAVE_SEARCH_API_KEY=

# Design Brain — scanned PDF OCR (Google Cloud Vision, ~$1.50/1000 pages, 1000 free/month)
GOOGLE_CLOUD_VISION_API_KEY=
PDF_OCR_MAX_PAGES=50

# Design Brain — nightly jobs (UTC hours via in-process scheduler)
BRAIN_NIGHTLY_CONSOLIDATE=false
BRAIN_NIGHTLY_RESEARCH=false
BRAIN_NIGHTLY_RESEARCH_MAX_SOURCES=8
# BRAIN_NIGHTLY_RESEARCH_HOUR_UTC=2
# BRAIN_NIGHTLY_RESEARCH_TOPICS=Swiss modernism logo,logo grid construction
# Shared knowledge scope used by every account (default: logo-modernism).
# BRAIN_GLOBAL_ORGANIZATION_SLUG=logo-modernism

# Persistent writable data (PDF uploads, generated logos, research queue)
# Local dev: defaults to <repo>/data (no extra config)
# Railway: create a Volume mounted at /app/persistent — Railway sets RAILWAY_VOLUME_MOUNT_PATH
# Do NOT mount the volume at /app/data (that hides catalog assets from git)
# PERSISTENT_DATA_DIR=/app/persistent
# Backend service: set DATABASE_URL + API keys. Optional:
# FRONTEND_URL=https://your-frontend.up.railway.app
# CORS_ORIGINS=https://your-frontend.up.railway.app,http://localhost:5173
#
# Frontend build (Vite): baked in at build time
# VITE_API_URL=https://logomodernism-production.up.railway.app/api
#
# Lemon Squeezy billing (server-side only)
# LEMON_SQUEEZY_API_KEY=
# LEMON_SQUEEZY_WEBHOOK_SECRET=
# LEMON_SQUEEZY_STORE_ID=
# Comma-separated variant IDs; the first ID in each family is used for checkout.
# LEMON_SQUEEZY_PLUS_VARIANT_IDS=
# LEMON_SQUEEZY_PRO_VARIANT_IDS=
# LEMON_SQUEEZY_LOGOS_10_VARIANT_IDS=
# LEMON_SQUEEZY_LOGOS_25_VARIANT_IDS=
# BILLING_PAST_DUE_GRACE_HOURS=72
#
# First OWNER provisioning (run locally; password is generated if omitted)
# OWNER_EMAIL=owner@example.com
# OWNER_NAME=Owner Name
# OWNER_ORGANIZATION_NAME=Logo Modernism
# OWNER_ORGANIZATION_SLUG=logo-modernism
# npm run db:provision-owner -w @logo-platform/database

# NODE_ENV=
# Optional: shared rate limiting. Not required for API readiness or background tasks.
# REDIS_URL=
# BACKGROUND_TASK_CONCURRENCY=1