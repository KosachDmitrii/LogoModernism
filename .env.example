# OpenAI
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_QUALITY=high
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_VISION_MODEL=gpt-4o-mini
OPENAI_TEXT_MODEL=gpt-4o-mini

# Supabase (Design Brain database)
# Dashboard → Project Settings → API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_PUBLISHABLE_KEY=

# Supabase Storage — catalog logo uploads (Settings → API → service_role key)
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_CATALOG_BUCKET=catalog-logos

# Dashboard → Project Settings → Database → Database password
SUPABASE_PROJECT_REF=YOUR_PROJECT_REF
SUPABASE_DB_PASSWORD=

# Recommended for long-running dev server (Supabase → Connect → Session pooler, port 5432)
# Host must be aws-0-REGION.pooler.supabase.com — not REGION.pooler.supabase.com
# Example (Sydney): aws-0-ap-southeast-2.pooler.supabase.com
# DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-ap-southeast-2.pooler.supabase.com:5432/postgres

# Prisma CLI connection for migrations/introspection (direct if available, otherwise session pooler)
# DIRECT_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-ap-southeast-2.pooler.supabase.com:5432/postgres

# Optional: direct connection if your network supports IPv6 or the project has the IPv4 add-on
# DATABASE_URL=postgresql://postgres:PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require

# Design Brain — web research (parallel search; Wikipedia + Archive always available)
TAVILY_API_KEY=
BRAVE_SEARCH_API_KEY=

# Design Brain — scanned PDF OCR (Google Cloud Vision, ~$1.50/1000 pages, 1000 free/month)
GOOGLE_CLOUD_VISION_API_KEY=
PDF_OCR_MAX_PAGES=50

# Design Brain — nightly jobs (UTC hours via in-process scheduler)
BRAIN_NIGHTLY_CONSOLIDATE=false
BRAIN_NIGHTLY_RESEARCH=false
BRAIN_NIGHTLY_RESEARCH_MAX_SOURCES=8
# BRAIN_NIGHTLY_RESEARCH_TOPICS=Swiss modernism logo,logo grid construction

# Production (Railway)
# Backend service: set DATABASE_URL + API keys. Optional:
# FRONTEND_URL=https://your-frontend.up.railway.app
# CORS_ORIGINS=https://your-frontend.up.railway.app,http://localhost:5173
#
# Frontend build (Vite): baked in at build time
# VITE_API_URL=https://logomodernism-production.up.railway.app/api
