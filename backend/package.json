{
  "name": "@logo-platform/backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "dev": "npm run build -w @logo-platform/design-brain && nest build && nest start --watch",
    "start": "node dist/main.js",
    "start:worker": "node dist/worker.js",
    "dev:worker": "node dist/worker.js",
    "test:e2e": "nest build && vitest run --config vitest.config.ts",
    "test:unit": "vitest run --config vitest.unit.config.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1087.0",
    "@aws-sdk/s3-request-presigner": "^3.1087.0",
    "@logo-platform/ai-engines": "*",
    "@logo-platform/database": "*",
    "@logo-platform/design-brain": "*",
    "@logo-platform/image-generator": "*",
    "@logo-platform/knowledge-base": "*",
    "@logo-platform/prompt-engine": "*",
    "@logo-platform/shared": "*",
    "@nestjs/common": "^11.1.28",
    "@nestjs/core": "^11.1.28",
    "@nestjs/platform-express": "^11.1.28",
    "@opentelemetry/auto-instrumentations-node": "^0.78.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.220.0",
    "@opentelemetry/sdk-node": "^0.220.0",
    "bullmq": "^5.80.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^16.4.7",
    "ioredis": "^5.11.1",
    "jose": "^5.10.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.24",
    "@nestjs/testing": "^11.1.28",
    "@types/express": "^5.0.0",
    "@types/multer": "^2.2.0",
    "@types/node": "^22.10.5",
    "@types/supertest": "^6.0.3",
    "supertest": "^7.1.4",
    "testcontainers": "^12.0.4",
    "typescript": "^5.7.3",
    "vitest": "^3.2.4"
  }
}
