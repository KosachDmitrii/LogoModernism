{
  "name": "@logo-platform/database",
  "version": "1.0.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "prisma generate && tsc",
    "test": "tsx --test tests/**/*.test.ts",
    "db:generate": "tsx scripts/prisma-cli.ts generate",
    "db:push": "tsx scripts/prisma-cli.ts db push",
    "db:migrate": "tsx scripts/prisma-cli.ts migrate dev",
    "db:migrate:deploy": "tsx scripts/prisma-cli.ts migrate deploy",
    "db:migrate:status": "tsx scripts/prisma-cli.ts migrate status",
    "db:backup": "tsx scripts/backup-database.ts",
    "db:invariants:snapshot": "tsx scripts/migration-invariants.ts snapshot",
    "db:invariants:verify": "tsx scripts/migration-invariants.ts verify",
    "db:tenant:backfill": "tsx scripts/backfill-legacy-tenant.ts",
    "db:provision-owner": "tsx scripts/provision-owner.ts",
    "db:logos:migrate-storage": "tsx scripts/migrate-inline-logos.ts",
    "db:studio": "tsx scripts/prisma-cli.ts studio",
    "db:supabase-check": "tsx scripts/supabase-check.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.3.0",
    "@supabase/supabase-js": "^2.110.5",
    "dotenv": "^16.4.7",
    "prisma": "^6.3.0"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
