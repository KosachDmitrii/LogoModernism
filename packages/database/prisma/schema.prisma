generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organizations OrganizationMember[]
  projects      Project[]
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  plan      Plan     @default(FREE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members  OrganizationMember[]
  projects Project[]
  brands   Brand[]
}

model OrganizationMember {
  id             String   @id @default(cuid())
  role           Role     @default(MEMBER)
  organizationId String
  userId         String
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
}

model Project {
  id             String        @id @default(cuid())
  name           String
  description    String?
  status         ProjectStatus @default(ACTIVE)
  organizationId String?
  userId         String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id])
  user         User?         @relation(fields: [userId], references: [id])
  brands       Brand[]
  promptRuns   PromptRun[]
  logos        Logo[]
}

model Brand {
  id             String   @id @default(cuid())
  name           String
  industry       String
  organizationId String?
  projectId      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id])
  project      Project?      @relation(fields: [projectId], references: [id])
  dna          BrandDNA?
  logos        Logo[]
}

model BrandDNA {
  id           String   @id @default(cuid())
  brandId      String   @unique
  personality  String?
  visualTraits Json
  psychology   Json
  principleIds String[]
  narrative    String?
  constraints  String[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  brand Brand @relation(fields: [brandId], references: [id], onDelete: Cascade)
}

model Logo {
  id          String    @id @default(cuid())
  name        String
  brandId     String?
  projectId   String?
  status      LogoStatus @default(DRAFT)
  svgContent  String?
  promptText  String?
  scores      Json?
  metadata    Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  brand    Brand?        @relation(fields: [brandId], references: [id])
  project  Project?      @relation(fields: [projectId], references: [id])
  versions LogoVersion[]
}

model LogoVersion {
  id        String   @id @default(cuid())
  logoId    String
  version   Int
  svgContent String?
  promptText String?
  scores    Json?
  changelog String?
  createdAt DateTime @default(now())

  logo Logo @relation(fields: [logoId], references: [id], onDelete: Cascade)

  @@unique([logoId, version])
}

model PromptRun {
  id          String   @id @default(cuid())
  projectId   String?
  industry    String
  companyName String?
  request     Json
  result      Json
  bestScore   Float?
  createdAt   DateTime @default(now())

  project Project?              @relation(fields: [projectId], references: [id])
  prompts ComposedPromptRecord[]
}

model ComposedPromptRecord {
  id                 String   @id
  promptRunId        String?
  industry           String
  companyName        String?
  text               String   @db.Text
  scores             Json
  dna                Json
  metadata           Json     @default("{}")
  selectedPrinciples Json     @default("[]")
  rank               Int?
  logos              Json     @default("[]")
  feedback           String?
  saved              Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  promptRun PromptRun? @relation(fields: [promptRunId], references: [id], onDelete: SetNull)

  @@index([promptRunId])
  @@index([createdAt])
}

model DesignPrinciple {
  id             String   @id
  name           String
  description    String
  category       String
  promptFragment String
  weight         Float    @default(1)
  tags           String[]
  compatibility  String[]
  antiPatterns   String[]
  syncedAt       DateTime @default(now())
}

model BrainExperience {
  id         String          @id @default(cuid())
  sourceType BrainSourceType
  title      String?
  content    String          @db.Text
  summary    String?         @db.Text
  metadata   Json            @default("{}")
  filePath   String?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  tasteSignals BrainTasteSignal[]
}

model BrainTasteSignal {
  id           String          @id @default(cuid())
  experienceId String?
  signalType   TasteSignalType
  score        Float
  context      String?         @db.Text
  metadata     Json            @default("{}")
  createdAt    DateTime        @default(now())

  experience BrainExperience? @relation(fields: [experienceId], references: [id], onDelete: SetNull)
}

model LearnedPrinciple {
  id             String   @id @default(cuid())
  category       String
  ruleText       String   @db.Text
  promptFragment String
  weight         Float    @default(1.0)
  confidence     Float    @default(0.5)
  sourceIds      String[] @default([])
  antiPatterns   String[] @default([])
  tags           String[] @default([])
  citations      Json     @default("[]")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

enum BrainSourceType {
  PDF
  IMAGE
  FEEDBACK
  CATALOG
  TEXT
}

enum TasteSignalType {
  LIKE
  DISLIKE
  APPROVE
  REJECT
  RATING
}

enum Plan {
  FREE
  PRO
  ENTERPRISE
}

enum Role {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum ProjectStatus {
  ACTIVE
  ARCHIVED
  COMPLETED
}

enum LogoStatus {
  DRAFT
  REVIEW
  APPROVED
  ARCHIVED
}
