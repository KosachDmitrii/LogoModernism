generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  name         String?
  platformRole PlatformRole @default(USER) @map("platform_role")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  organizations   OrganizationMember[]
  projects        Project[]
  usageOperations UsageOperation[]
  checkoutSessions BillingCheckoutSession[]

  @@map("users")
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  plan      Plan     @default(FREE)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  members           OrganizationMember[]
  projects          Project[]
  brands            Brand[]
  generatedPrompts  ComposedPromptRecord[]
  generatedLogos    Logo[]
  brainExperiences  BrainExperience[]
  tasteSignals      BrainTasteSignal[]
  learnedPrinciples LearnedPrinciple[]
  researchCandidates BrainResearchCandidate[]
  billingSubscription BillingSubscription?
  billingCheckoutSessions BillingCheckoutSession[]
  usageBuckets      UsageBucket[]
  usageOperations   UsageOperation[]
  creditBalance     CreditBalance?

  @@map("organizations")
}

model OrganizationMember {
  id             String   @id @default(cuid())
  role           Role     @default(MEMBER)
  organizationId String   @map("organization_id")
  userId         String   @map("user_id")
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade, map: "organization_members_organization_id_fkey")
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade, map: "organization_members_user_id_fkey")

  @@unique([organizationId, userId], map: "organization_members_organization_id_user_id_key")
  @@index([userId], map: "organization_members_user_id_idx")
  @@map("organization_members")
}

model Project {
  id             String        @id @default(cuid())
  name           String
  description    String?
  status         ProjectStatus @default(ACTIVE)
  organizationId String?       @map("organization_id")
  userId         String?       @map("user_id")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  organization      Organization?          @relation(fields: [organizationId], references: [id], map: "projects_organization_id_fkey")
  user              User?                  @relation(fields: [userId], references: [id], map: "projects_user_id_fkey")
  brands            Brand[]
  promptRuns        PromptRun[]
  logos             Logo[]
  generatedPrompts  ComposedPromptRecord[]
  brainExperiences  BrainExperience[]
  tasteSignals      BrainTasteSignal[]
  learnedPrinciples LearnedPrinciple[]
  researchCandidates BrainResearchCandidate[]

  @@index([organizationId, createdAt(sort: Desc)], map: "projects_organization_id_created_at_idx")
  @@index([userId], map: "projects_user_id_idx")
  @@map("projects")
}

model Brand {
  id             String   @id @default(cuid())
  name           String
  industry       String
  organizationId String?  @map("organization_id")
  projectId      String?  @map("project_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization? @relation(fields: [organizationId], references: [id], map: "brands_organization_id_fkey")
  project      Project?      @relation(fields: [projectId], references: [id], map: "brands_project_id_fkey")
  dna          BrandDNA?
  logos        Logo[]

  @@index([organizationId, createdAt(sort: Desc)], map: "brands_organization_id_created_at_idx")
  @@index([projectId], map: "brands_project_id_idx")
  @@map("brands")
}

model BrandDNA {
  id           String   @id @default(cuid())
  brandId      String   @unique(map: "brand_profiles_brand_id_key") @map("brand_id")
  personality  String?
  visualTraits Json     @map("visual_traits")
  psychology   Json
  principleIds String[] @map("principle_ids")
  narrative    String?
  constraints  String[]
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  brand Brand @relation(fields: [brandId], references: [id], onDelete: Cascade, map: "brand_profiles_brand_id_fkey")

  @@map("brand_profiles")
}

model Logo {
  id             String     @id @default(cuid())
  name           String
  brandId        String?    @map("brand_id")
  organizationId String?    @map("organization_id")
  projectId      String?    @map("project_id")
  promptId       String?    @map("prompt_id")
  status         LogoStatus @default(DRAFT)
  storageKey     String?    @map("storage_key")
  publicUrl      String?    @map("public_url")
  mimeType       String?    @map("mime_type")
  width          Int?
  height         Int?
  provider       String?
  model          String?
  svgContent     String?    @map("svg_content")
  promptText     String?    @map("prompt_text")
  scores         Json?
  metadata       Json?
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  brand        Brand?                @relation(fields: [brandId], references: [id], map: "generated_logos_brand_id_fkey")
  organization Organization?         @relation(fields: [organizationId], references: [id], onDelete: Cascade, map: "generated_logos_organization_id_fkey")
  project      Project?              @relation(fields: [projectId], references: [id], map: "generated_logos_project_id_fkey")
  prompt       ComposedPromptRecord? @relation(fields: [promptId], references: [id], onDelete: SetNull, map: "generated_logos_prompt_id_fkey")
  versions     LogoVersion[]

  @@index([projectId, createdAt(sort: Desc)], map: "generated_logos_project_id_created_at_idx")
  @@index([organizationId, createdAt(sort: Desc)], map: "generated_logos_organization_id_created_at_idx")
  @@index([brandId], map: "generated_logos_brand_id_idx")
  @@index([promptId], map: "generated_logos_prompt_id_idx")
  @@map("generated_logos")
}

model LogoVersion {
  id         String   @id @default(cuid())
  logoId     String   @map("logo_id")
  version    Int
  storageKey String?  @map("storage_key")
  svgContent String?  @map("svg_content")
  promptText String?  @map("prompt_text")
  scores     Json?
  changelog  String?
  createdAt  DateTime @default(now()) @map("created_at")

  logo Logo @relation(fields: [logoId], references: [id], onDelete: Cascade, map: "generated_logo_versions_logo_id_fkey")

  @@unique([logoId, version], map: "generated_logo_versions_logo_id_version_key")
  @@map("generated_logo_versions")
}

model PromptRun {
  id          String   @id @default(cuid())
  projectId   String?  @map("project_id")
  industry    String
  companyName String?  @map("company_name")
  request     Json
  result      Json
  bestScore   Float?   @map("best_score")
  createdAt   DateTime @default(now()) @map("created_at")

  project Project?               @relation(fields: [projectId], references: [id], map: "prompt_generation_runs_project_id_fkey")
  prompts ComposedPromptRecord[]

  @@index([projectId, createdAt(sort: Desc)], map: "prompt_generation_runs_project_id_created_at_idx")
  @@map("prompt_generation_runs")
}

model ComposedPromptRecord {
  id                 String    @id
  promptRunId        String?   @map("prompt_run_id")
  organizationId     String?   @map("organization_id")
  projectId          String?   @map("project_id")
  industry           String
  companyName        String?   @map("company_name")
  text               String    @db.Text
  scores             Json
  dna                Json
  metadata           Json      @default("{}")
  selectedPrinciples Json      @default("[]") @map("selected_principles")
  rank               Int?
  logos              Json      @default("[]")
  feedback           String?
  saved              Boolean   @default(false)
  savedAt            DateTime? @map("saved_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  promptRun      PromptRun?    @relation(fields: [promptRunId], references: [id], onDelete: SetNull, map: "generated_prompts_prompt_run_id_fkey")
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade, map: "generated_prompts_organization_id_fkey")
  project        Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull, map: "generated_prompts_project_id_fkey")
  generatedLogos Logo[]

  @@index([promptRunId], map: "generated_prompts_prompt_run_id_idx")
  @@index([organizationId, createdAt(sort: Desc)], map: "generated_prompts_organization_id_created_at_idx")
  @@index([projectId, createdAt(sort: Desc)], map: "generated_prompts_project_id_created_at_idx")
  @@index([savedAt(sort: Desc), id(sort: Desc)], map: "generated_prompts_saved_at_id_idx")
  @@map("generated_prompts")
}

model BrainExperience {
  id             String          @id @default(cuid())
  sourceType     BrainSourceType @map("source_type")
  title          String?
  content        String          @db.Text
  summary        String?         @db.Text
  metadata       Json            @default("{}")
  filePath       String?         @map("file_path")
  organizationId String?         @map("organization_id")
  projectId      String?         @map("project_id")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  tasteSignals BrainTasteSignal[]
  organization Organization?      @relation(fields: [organizationId], references: [id], onDelete: Cascade, map: "design_brain_experiences_organization_id_fkey")
  project      Project?           @relation(fields: [projectId], references: [id], onDelete: SetNull, map: "design_brain_experiences_project_id_fkey")

  @@index([createdAt(sort: Desc)], map: "design_brain_experiences_created_at_idx")
  @@index([organizationId, projectId, createdAt(sort: Desc)], map: "design_brain_experiences_tenant_created_at_idx")
  @@map("design_brain_experiences")
}

model BrainTasteSignal {
  id             String          @id @default(cuid())
  experienceId   String?         @map("experience_id")
  signalType     TasteSignalType @map("signal_type")
  score          Float
  context        String?         @db.Text
  metadata       Json            @default("{}")
  organizationId String?         @map("organization_id")
  projectId      String?         @map("project_id")
  createdAt      DateTime        @default(now()) @map("created_at")

  experience   BrainExperience? @relation(fields: [experienceId], references: [id], onDelete: SetNull, map: "design_brain_taste_signals_experience_id_fkey")
  organization Organization?    @relation(fields: [organizationId], references: [id], onDelete: Cascade, map: "design_brain_taste_signals_organization_id_fkey")
  project      Project?         @relation(fields: [projectId], references: [id], onDelete: SetNull, map: "design_brain_taste_signals_project_id_fkey")

  @@index([createdAt(sort: Desc)], map: "design_brain_taste_signals_created_at_idx")
  @@index([organizationId, projectId, createdAt(sort: Desc)], map: "design_brain_taste_signals_tenant_created_at_idx")
  @@map("design_brain_taste_signals")
}

model LearnedPrinciple {
  id             String   @id @default(cuid())
  category       String
  ruleText       String   @map("rule_text") @db.Text
  promptFragment String   @map("prompt_fragment")
  weight         Float    @default(1.0)
  confidence     Float    @default(0.5)
  sourceIds      String[] @default([]) @map("source_ids")
  antiPatterns   String[] @default([]) @map("anti_patterns")
  tags           String[] @default([])
  citations      Json     @default("[]")
  organizationId String?  @map("organization_id")
  projectId      String?  @map("project_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade, map: "learned_design_principles_organization_id_fkey")
  project      Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull, map: "learned_design_principles_project_id_fkey")

  @@index([organizationId, projectId, confidence(sort: Desc)], map: "learned_design_principles_tenant_confidence_idx")
  @@map("learned_design_principles")
}

model BrainResearchCandidate {
  id             String   @id
  organizationId String   @map("organization_id")
  projectId      String?  @map("project_id")
  createdBy      String?  @map("created_by")
  reviewedBy     String?  @map("reviewed_by")
  query          String
  status         String   @default("pending")
  sourceUrl      String   @db.Text @map("source_url")
  sourceTitle    String   @map("source_title")
  snippet        String   @db.Text
  summary        String   @db.Text
  extractedText  String   @db.Text @map("extracted_text")
  principles     Json
  sourceScore    Float?   @map("source_score")
  ingestResult   Json?    @map("ingest_result")
  createdAt      DateTime @default(now()) @map("created_at")
  reviewedAt     DateTime? @map("reviewed_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade, map: "brain_research_candidates_organization_id_fkey")
  project      Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull, map: "brain_research_candidates_project_id_fkey")

  @@index([organizationId, status, createdAt(sort: Desc)], map: "brain_research_candidates_tenant_status_created_at_idx")
  @@index([organizationId, projectId], map: "brain_research_candidates_tenant_project_idx")
  @@map("brain_research_candidates")
}

model OutboxEvent {
  id             String    @id @default(cuid())
  aggregateType  String    @map("aggregate_type")
  aggregateId    String    @map("aggregate_id")
  eventType      String    @map("event_type")
  payload        Json
  idempotencyKey String    @unique(map: "outbox_events_idempotency_key_key") @map("idempotency_key")
  status         String    @default("pending")
  attempts       Int       @default(0)
  availableAt    DateTime  @default(now()) @map("available_at")
  processedAt    DateTime? @map("processed_at")
  lastError      String?   @map("last_error")
  createdAt      DateTime  @default(now()) @map("created_at")

  @@index([status, availableAt], map: "outbox_events_status_available_at_idx")
  @@map("outbox_events")
}

model BillingSubscription {
  id                     String                    @id @default(cuid())
  organizationId         String                    @unique(map: "billing_subscriptions_organization_id_key") @map("organization_id")
  provider               BillingProvider           @default(LEMON_SQUEEZY)
  providerCustomerId     String?                   @map("provider_customer_id")
  providerSubscriptionId String?                   @unique(map: "billing_subscriptions_provider_subscription_id_key") @map("provider_subscription_id")
  providerOrderId        String?                   @map("provider_order_id")
  productId              String?                   @map("product_id")
  variantId              String?                   @map("variant_id")
  plan                   Plan                      @default(FREE)
  status                 BillingSubscriptionStatus @default(INACTIVE)
  renewsAt               DateTime?                 @map("renews_at")
  endsAt                 DateTime?                 @map("ends_at")
  providerUpdatedAt      DateTime?                 @map("provider_updated_at")
  createdAt              DateTime                  @default(now()) @map("created_at")
  updatedAt              DateTime                  @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade, map: "billing_subscriptions_organization_id_fkey")

  @@index([status, providerUpdatedAt], map: "billing_subscriptions_status_updated_idx")
  @@map("billing_subscriptions")
}

model BillingCheckoutSession {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  requestedBy    String   @map("requested_by")
  plan           Plan
  variantId      String   @map("variant_id")
  nonceHash      String   @unique(map: "billing_checkout_sessions_nonce_hash_key") @map("nonce_hash")
  expiresAt      DateTime @map("expires_at")
  consumedAt     DateTime? @map("consumed_at")
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade, map: "billing_checkout_sessions_organization_id_fkey")
  requester    User         @relation(fields: [requestedBy], references: [id], onDelete: Cascade, map: "billing_checkout_sessions_requested_by_fkey")

  @@index([organizationId, expiresAt], map: "billing_checkout_sessions_org_expires_idx")
  @@map("billing_checkout_sessions")
}

model BillingWebhookEvent {
  id          String             @id
  provider    BillingProvider    @default(LEMON_SQUEEZY)
  eventName   String             @map("event_name")
  resourceId  String?            @map("resource_id")
  status      BillingEventStatus @default(RECEIVED)
  error       String?            @db.Text
  receivedAt  DateTime           @default(now()) @map("received_at")
  processedAt DateTime?          @map("processed_at")

  @@index([status, receivedAt], map: "billing_webhook_events_status_received_idx")
  @@map("billing_webhook_events")
}

model UsageBucket {
  id                String   @id @default(cuid())
  organizationId    String   @map("organization_id")
  periodStart       DateTime @map("period_start")
  periodEnd         DateTime @map("period_end")
  plan              Plan
  includedCredits   Int      @map("included_credits")
  reservedCredits   Int      @default(0) @map("reserved_credits")
  committedCredits  Int      @default(0) @map("committed_credits")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade, map: "usage_buckets_organization_id_fkey")
  operations   UsageOperation[]

  @@unique([organizationId, periodStart], map: "usage_buckets_organization_period_key")
  @@index([periodEnd], map: "usage_buckets_period_end_idx")
  @@map("usage_buckets")
}

model UsageOperation {
  id                       String                 @id @default(cuid())
  organizationId           String                 @map("organization_id")
  userId                   String?                @map("user_id")
  projectId                String?                @map("project_id")
  bucketId                 String                 @map("bucket_id")
  operationKey             String                 @map("operation_key")
  idempotencyKey           String                 @map("idempotency_key")
  status                   UsageReservationStatus @default(RESERVED)
  reservedCredits          Int                    @map("reserved_credits")
  includedReservedCredits  Int                    @default(0) @map("included_reserved_credits")
  purchasedReservedCredits Int                    @default(0) @map("purchased_reserved_credits")
  actualCredits            Int?                   @map("actual_credits")
  jobId                    String?                @map("job_id")
  metadata                 Json                   @default("{}")
  expiresAt                DateTime               @map("expires_at")
  createdAt                DateTime               @default(now()) @map("created_at")
  updatedAt                DateTime               @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade, map: "usage_operations_organization_id_fkey")
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull, map: "usage_operations_user_id_fkey")
  bucket       UsageBucket  @relation(fields: [bucketId], references: [id], onDelete: Cascade, map: "usage_operations_bucket_id_fkey")

  @@unique([organizationId, idempotencyKey], map: "usage_operations_org_idempotency_key")
  @@index([status, expiresAt], map: "usage_operations_status_expires_idx")
  @@index([organizationId, operationKey, createdAt], map: "usage_operations_org_key_created_idx")
  @@map("usage_operations")
}

model CreditBalance {
  organizationId  String   @id @map("organization_id")
  availableCredits Int     @default(0) @map("available_credits")
  updatedAt       DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade, map: "credit_balances_organization_id_fkey")

  @@map("credit_balances")
}

enum PlatformRole {
  USER
  PLATFORM_ADMIN
}

enum BillingProvider {
  LEMON_SQUEEZY
}

enum BillingSubscriptionStatus {
  INACTIVE
  ON_TRIAL
  ACTIVE
  PAUSED
  PAST_DUE
  UNPAID
  CANCELLED
  EXPIRED
}

enum BillingEventStatus {
  RECEIVED
  PROCESSED
  IGNORED
  FAILED
}

enum UsageReservationStatus {
  RESERVED
  PROCESSING
  COMMITTED
  RELEASED
  EXPIRED
}

enum BrainSourceType {
  PDF
  IMAGE
  FEEDBACK
  CATALOG
  TEXT
}

enum TasteSignalType {
  LIKE
  DISLIKE
  APPROVE
  REJECT
  RATING
}

enum Plan {
  FREE
  PRO
  ENTERPRISE
}

enum Role {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum ProjectStatus {
  ACTIVE
  ARCHIVED
  COMPLETED
}

enum LogoStatus {
  DRAFT
  REVIEW
  APPROVED
  ARCHIVED
}
